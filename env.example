# ============================================
# Automation Master Bot - Environment Variables
# ============================================
# On Railway: Set these in the Variables tab
# Locally: Copy this file to .env and fill values

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ── Gemini API Keys (rotation) ──
# Add as many as you want. Bot auto-switches when one hits daily limit.
GEMINI_API_KEY_1=your_first_gemini_key
GEMINI_API_KEY_2=your_second_gemini_key
GEMINI_API_KEY_3=your_third_gemini_key

# ── Browser ──
HEADLESS=true
CHROMIUM_PATH=/usr/bin/chromium
USER_DATA_DIR=/data/user_data
